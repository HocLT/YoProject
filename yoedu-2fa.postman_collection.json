{
	"info": {
		"_postman_id": "e2f7b140-1662-43e8-a15d-045330e7df5d",
		"name": "YoEdu 2FA Auth Collection",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Register (Optional)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"username\": \"testuser\",\r\n  \"password\": \"123456\",\r\n  \"fullName\": \"Test User\",\r\n  \"email\": \"test@test.com\",\r\n  \"phone\": \"0123456789\"\r\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/auth/register",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"auth",
						"register"
					]
				}
			}
		},
		{
			"name": "2. Login (Before 2FA / Get JWT)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.data && jsonData.data.accessToken) {",
							"    pm.collectionVariables.set(\"jwt_token\", jsonData.data.accessToken);",
							"}",
							"if (jsonData.data && jsonData.data.requires2fa) {",
							"    pm.collectionVariables.set(\"temp_token\", jsonData.data.tempToken);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"username\": \"testuser\",\r\n  \"password\": \"123456\"\r\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/auth/login",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"auth",
						"login"
					]
				}
			}
		},
		{
			"name": "3. Generate 2FA Setup",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{jwt_token}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/auth/2fa/generate",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"auth",
						"2fa",
						"generate"
					]
				}
			}
		},
		{
			"name": "4. Enable 2FA",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{jwt_token}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"code\": \"REPLACE_WITH_6_DIGIT_CODE\"\r\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/auth/2fa/enable",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"auth",
						"2fa",
						"enable"
					]
				}
			}
		},
		{
			"name": "5. Verify 2FA Login (Final Step)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.data && jsonData.data.accessToken) {",
							"    pm.collectionVariables.set(\"jwt_token\", jsonData.data.accessToken);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"tempToken\": \"{{temp_token}}\",\r\n  \"code\": \"REPLACE_WITH_6_DIGIT_CODE\"\r\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/auth/login/2fa",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"auth",
						"login",
						"2fa"
					]
				}
			}
		}
	],
	"variable": [
		{
			"key": "jwt_token",
			"value": ""
		},
		{
			"key": "temp_token",
			"value": ""
		}
	]
}
